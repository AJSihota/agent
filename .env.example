# Retell AI API Keys
# Obtain from: https://app.retellai.com/
# Add these as environment variables in your Vercel project dashboard
# (Settings → Environment Variables) — never commit real values here.

# Primary API key (used by the main site demo endpoint)
RETELL_API_KEY=

# Secondary API key (used by the embed endpoint for crypto and hvac demos)
RETELL_API_KEY_EMBED=

# Retell Agent IDs — main site (create-call endpoint)
RETELL_AGENT_EV=
RETELL_AGENT_CRYPTO=
RETELL_AGENT_HVAC=

# Retell Agent ID — embed endpoint EV demo (may differ from main site)
RETELL_AGENT_EV_EMBED=
